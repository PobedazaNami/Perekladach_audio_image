# =======================================================
# CONFIGURATION TEMPLATE FOR TELEGRAM TRANSLATION BOT
# =======================================================
# 
# ⚠️ ВАЖНО: Скопируйте этот файл в .env и заполните реальными значениями
# ⚠️ WARNING: Copy this file to .env and fill with real values
#

# =======================================================
# TELEGRAM BOT CONFIGURATION
# =======================================================
# Получите токен у @BotFather в Telegram
# Get token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID администраторов бота (через запятую)
# Bot administrators IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# =======================================================
# REDIS CACHE CONFIGURATION (для максимальной производительности)
# =======================================================
# Redis URL для кэширования (опционально, улучшает скорость)
# Redis URL for caching (optional, improves performance)
REDIS_URL=redis://localhost:6379/0

# =======================================================
# OPENAI API CONFIGURATION
# =======================================================
# API ключ OpenAI для переводов
# OpenAI API key for translations
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# =======================================================
# MONGODB ATLAS CONFIGURATION (MAIN DATABASE)
# =======================================================
# URI подключения к MongoDB Atlas
# MongoDB Atlas connection URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=yourapp

# Название базы данных MongoDB
# MongoDB database name
MONGODB_DATABASE=translation_bot

# Время жизни кеша в часах
# Cache TTL in hours
CACHE_TTL_HOURS=24

# =======================================================
# LEGACY MYSQL CONFIGURATION (FALLBACK)
# =======================================================
# Конфигурация для MySQL (используется как резерв)
# MySQL configuration (used as fallback)
DATABASE_TYPE=mysql
DATABASE_HOST=your_mysql_host
DATABASE_PORT=3306
DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password

# =======================================================
# GOOGLE CLOUD CONFIGURATION
# =======================================================
# Путь к JSON файлу с ключами Google Cloud API
# Path to Google Cloud API JSON key file
GOOGLE_APPLICATION_CREDENTIALS=credentials/vision-api-key.json

# =======================================================
# REDIS CONFIGURATION (OPTIONAL)
# =======================================================
# URL для подключения к Redis (опционально)
# Redis connection URL (optional)
REDIS_PUBLIC_URL=redis://default:password@host:port

# =======================================================
# DEPLOYMENT CONFIGURATION
# =======================================================
# Порт для веб-сервера (для health checks)
# Web server port (for health checks)
PORT=8000

# Режим работы: development, production
# Environment mode: development, production
ENVIRONMENT=development

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO