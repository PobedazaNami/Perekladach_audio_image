# =======================================================
# COMPREHENSIVE .gitignore FOR TELEGRAM TRANSLATION BOT
# =======================================================

# =======================================================
# SENSITIVE DATA AND SECRETS
# =======================================================
# Environment variables with secrets
.env
.env.local
.env.production
.env.development

# Google Cloud credentials
credentials/
*.json
service-account*.json
gcp-key*.json

# SSH keys and certificates
*.pem
*.key
*.crt
*.p12

# Database dumps
*.sql
*.db
*.sqlite
*.sqlite3

# =======================================================
# PYTHON
# =======================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# =======================================================
# LOGS AND DEBUGGING
# =======================================================
*.log
logs/
debug.log
error.log
bot.log
app.log

# =======================================================
# DOCKER
# =======================================================
# Docker volumes and data
docker-compose.override.yml
.dockerignore

# =======================================================
# SYSTEM FILES
# =======================================================
# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~

# =======================================================
# IDE AND EDITORS
# =======================================================
# Visual Studio Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iws
*.iml
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =======================================================
# TEMPORARY FILES
# =======================================================
# Temporary directories
tmp/
temp/
.tmp/
.temp/

# Cache directories
.cache/
cache/
.npm/

# =======================================================
# PROJECT SPECIFIC
# =======================================================
# Test files
test_*.py
*_test.py
reset_*.py

# Backup files
*.bak
*.backup
*.orig
*.save

# Media files (if any)
uploads/
media/
images/
audio/
video/

# Reports and documentation
reports/
docs/_build/
docs/
ffmpeg/doc/
ffmpeg/README.txt
# =======================================================
# DEVELOPMENT AND TESTING FILES (TO EXCLUDE)
# =======================================================
# Test files
test_*.py
*_test.py
simple_test.py
performance_test.py

# Development documentation
DEPLOYMENT.md
PERFORMANCE_GUIDE.md
OPTIMIZATION_SUMMARY.md
MongoDB_README.md

# Development utilities
switch_version.py
reset_*.py

# Old/backup files
*_old.py
*_backup.py
*.bak